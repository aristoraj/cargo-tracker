# Copy to .env for local dev. On Render, set these as service Environment
# Variables instead (never commit a real .env file).

PORT=3000

# Secrets — get these from your Zoho API console / self-client setup.
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=

# Non-secret config — depends on your Zoho data center (.com / .in / .eu / .com.cn / .jp / .com.au).
ZOHO_ACCOUNTS_DOMAIN=accounts.zoho.in
ZOHO_API_DOMAIN=www.zohoapis.in
ZOHO_ACCOUNT_OWNER_NAME=

# Creator app/form link names (must match what was created in Zoho Creator).
ZOHO_APP_LINK_NAME=Cargo_Tracker
ZOHO_FORM_LINK_NAME=Scan_Event
ZOHO_REPORT_LINK_NAME=All_Scan_Events
ZOHO_IMAGE_FIELD=Scanned_Image

# Some Zoho DCs/API versions only accept POST for the file-upload endpoint
# even though we expose PATCH to the widget — verify against your API docs.
ZOHO_UPLOAD_METHOD=POST

# Restrict to your widget's actual origin once known; '*' is fine for prototyping.
ALLOWED_ORIGIN=*
